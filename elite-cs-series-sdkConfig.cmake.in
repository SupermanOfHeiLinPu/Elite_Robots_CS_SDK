@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/elite-cs-series-sdkTargets.cmake")

if(NOT TARGET elite-cs-series-sdk::shared)
  add_library(elite-cs-series-sdk::shared INTERFACE IMPORTED)
  set_property(TARGET elite-cs-series-sdk::shared PROPERTY
    INTERFACE_LINK_LIBRARIES elite_cs_series_sdk_SHARED)
endif()

if(NOT TARGET elite-cs-series-sdk::static)
  add_library(elite-cs-series-sdk::static INTERFACE IMPORTED)
  set_property(TARGET elite-cs-series-sdk::static PROPERTY
    INTERFACE_LINK_LIBRARIES elite_cs_series_sdk_STATIC)
endif()
