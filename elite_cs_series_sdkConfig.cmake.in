@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/elite_cs_series_sdkTargets.cmake")

if(NOT TARGET elite_cs_series_sdk::shared)
  add_library(elite_cs_series_sdk::shared INTERFACE IMPORTED)
  set_property(TARGET elite_cs_series_sdk::shared PROPERTY
    INTERFACE_LINK_LIBRARIES elite_cs_series_sdk_SHARED)
endif()

if(NOT TARGET elite_cs_series_sdk::static)
  add_library(elite_cs_series_sdk::static INTERFACE IMPORTED)
  set_property(TARGET elite_cs_series_sdk::static PROPERTY
    INTERFACE_LINK_LIBRARIES elite_cs_series_sdk_STATIC)
endif()
